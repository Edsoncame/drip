# ══════════════════════════════════════════════════════════════════════════
# Flux — Environment Variables Template
#
# Copy to .env.local for local dev (never commit .env.local).
# In production, set these in Vercel Dashboard → Settings → Environment Variables.
# ══════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:port/db

# ── Anthropic (Claude agents + KYC OCR) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe (pagos USD — Flux Peru, LLC) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Vercel Blob (uploads de DNI, selfies, invoices) ────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ── AWS Rekognition (face-match biométrico en KYC) ─────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# ── KYC umbrales (opcionales — tienen defaults) ────────────────────────────
KYC_NAME_MATCH_MIN=0.90
KYC_NAME_MATCH_REVIEW=0.80
KYC_FACE_MATCH_MIN=85
KYC_LIVENESS_YAW_MIN=10
NEXT_PUBLIC_KYC_BLUR_THRESHOLD=40

# ── KYC forense (Fase 4 del pipeline P2-1) ────────────────────────────────
# Modo observación: en 'false' las capas forenses calculan y persisten scores
# pero NO rechazan ni fuerzan arbiter — solo loguean. Poner 'true' cuando se
# valide que los fixtures están calibrados y los thresholds son correctos.
KYC_FORENSICS_ENFORCE=false
# overall_tampering_risk ≥ este umbral → auto-reject (sin arbiter)
KYC_FORENSICS_REJECT_THRESHOLD=0.75
# overall_tampering_risk ≥ este umbral → fuerza arbiter
KYC_FORENSICS_ARBITER_THRESHOLD=0.4
# template layout_score < este umbral → fuerza arbiter
KYC_TEMPLATE_MIN_SCORE=0.6
# tolerancia en años del rango Rekognition vs dni_age
KYC_AGE_TOLERANCE_YEARS=3
# chequeo cross-user de selfies similares. 'off' por default (no implementado
# sin Rekognition Collection; solo chequeamos duplicados por dni_number)
KYC_SELFIE_DUPLICATE_CHECK=off

# ── Meta Ads (agentes de marketing — sem-manager, community-manager) ──────
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=act_...
META_PAGE_ID=
META_INSTAGRAM_ID=
META_API_VERSION=v19.0

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-32-bytes-hex
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Vault (credenciales cifradas AES-256-GCM) ──────────────────────────────
VAULT_SECRET=change-me-32-bytes-hex

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.fluxperu.com
ADMIN_EMAILS=edsoncame@fluxperu.com
NEXT_PUBLIC_GTM_ID=GTM-MW37Y2IN

# ── Autopilot cost cap (agentes de marketing, opcional) ────────────────────
DAILY_AUTOPILOT_COST_CAP_USD=20
